# Voice Agent — Environment Variables
# Copy this file to .env and fill in your API keys.
# The agent works fully offline with local models (Ollama + Kokoro + DistilWhisper).
# API keys are only needed for cloud providers.

# ─── Speech-To-Text ────────────────────────────────────────────────────────────

# Deepgram real-time streaming STT (optional — local DistilWhisper works offline)
# Get key at: https://deepgram.com
DEEPGRAM_API_KEY=

# AssemblyAI real-time streaming STT (optional)
# Get key at: https://assemblyai.com
ASSEMBLYAI_API_KEY=

# ─── Large Language Models ─────────────────────────────────────────────────────

# Groq — fast cloud LLM inference (free tier available, very low latency)
# Get key at: https://console.groq.com
GROQ_API_KEY=

# OpenRouter — access many models via one API key (Phase 4B.2)
# Get key at: https://openrouter.ai
OPENROUTER_API_KEY=

# OpenAI — GPT models (Phase 4B.2)
# Get key at: https://platform.openai.com
OPENAI_API_KEY=

# ─── Text-To-Speech ────────────────────────────────────────────────────────────

# ElevenLabs — high quality TTS (Phase 4B.2)
# Get key at: https://elevenlabs.io
ELEVENLABS_API_KEY=

# ─── Local Model Paths (no API key needed) ─────────────────────────────────────
# These paths are configured in config/models.yaml, not here.
# Kokoro model: weights/kokoro-v0_19.onnx + weights/voices.bin
# Piper model: weights/en_US-lessac-medium.onnx + .json
# DistilWhisper: downloaded automatically by faster-whisper on first run
